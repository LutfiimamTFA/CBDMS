
{
  "entities": {
    "User": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "User",
      "type": "object",
      "description": "Represents a user in the WorkWise application.",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the User entity."
        },
        "name": {
          "type": "string",
          "description": "The user's full name."
        },
        "email": {
          "type": "string",
          "description": "The user's email address.",
          "format": "email"
        },
        "avatarUrl": {
            "type": "string",
            "description": "URL of the user's profile picture.",
            "format": "uri"
        },
        "role": {
            "type": "string",
            "description": "The role of the user, determining their access level.",
            "enum": ["Super Admin", "Manager", "PIC", "Employee", "Client"]
        },
        "companyId": {
            "type": "string",
            "description": "The ID of the company the user belongs to."
        },
        "managerId": {
            "type": "string",
            "description": "The ID of the User (with Manager role) who is the direct supervisor of this user. Empty for Managers and Super Admins."
        },
        "brandIds": {
            "type": "array",
            "description": "For Managers, an array of Brand IDs they are responsible for. This defines their scope of work.",
            "items": { "type": "string" }
        },
        "createdAt": {
          "type": "string",
          "description": "The timestamp when the user was created.",
          "format": "date-time"
        }
      },
      "required": [
        "id",
        "name",
        "email",
        "role",
        "companyId",
        "createdAt"
      ]
    },
    "Company": {
        "$schema": "http://json-schema.org/draft-07/schema#",
        "title": "Company",
        "type": "object",
        "description": "Represents a company.",
        "properties": {
            "id": {
                "type": "string",
                "description": "Unique identifier for the Company entity."
            },
            "name": {
                "type": "string",
                "description": "The name of the company."
            },
            "logoUrl": {
                "type": "string",
                "description": "URL of the company logo.",
                "format": "uri"
            }
        },
        "required": ["id", "name"]
    },
    "CompanySettings": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "CompanySettings",
      "type": "object",
      "description": "Stores company-wide settings, including the designated emergency admin.",
      "properties": {
        "emergencyAdminUserId": {
          "type": ["string", "null"],
          "description": "The ID of the User (Manager) who is currently designated as the emergency Super Admin. Null if no one is designated."
        }
      }
    },
    "Brand": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Brand",
      "type": "object",
      "description": "Represents a brand or division within the company.",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the Brand entity."
        },
        "name": {
          "type": "string",
          "description": "The name of the brand."
        },
        "createdAt": {
          "type": "string",
          "description": "The timestamp when the brand was created.",
          "format": "date-time"
        }
      },
      "required": ["id", "name", "createdAt"]
    },
    "Task": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Task",
      "type": "object",
      "description": "Represents a task within the WorkWise application.",
      "properties": {
        "id": { "type": "string" },
        "brandId": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "status": { "type": "string" },
        "assigneeIds": { "type": "array", "items": { "type": "string" } },
        "startDate": { "type": "string", "format": "date-time" },
        "dueDate": { "type": "string", "format": "date-time" },
        "actualStartDate": { "type": "string", "format": "date-time" },
        "actualCompletionDate": { "type": "string", "format": "date-time" },
        "currentSessionStartTime": { "type": "string", "format": "date-time" },
        "priority": { "type": "string" },
        "timeEstimate": { "type": "number" },
        "waitingOnTaskIds": { "type": "array", "items": { "type": "string" }, "description": "Tasks that must be completed before this task can start." },
        "blockingTaskIds": { "type": "array", "items": { "type": "string" }, "description": "Tasks that are blocked by this task." },
        "linkedTaskIds": { "type": "array", "items": { "type": "string" }, "description": "Tasks that are related but not dependent." },
        "lastActivity": { "$ref": "#/backend/entities/Activity" },
        "companyId": { "type": "string" },
        "revisionItems": {
            "type": "array",
            "description": "A checklist of items that need to be revised for the current revision cycle.",
            "items": { "$ref": "#/backend/entities/RevisionItem" }
        },
        "revisionHistory": {
            "type": "array",
            "description": "A log of all past revision cycles for this task.",
            "items": { "$ref": "#/backend/entities/RevisionCycle" }
        },
        "deliverables": {
            "type": "array",
            "description": "A list of submitted files or links for this task, with historical versions.",
            "items": { "$ref": "#/backend/entities/Attachment" }
        }
      },
      "required": ["id", "brandId", "title", "status", "assigneeIds", "priority", "companyId"]
    },
    "WebArticle": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "WebArticle",
      "type": "object",
      "description": "Represents a web article, which is a specialized type of task.",
      "properties": {
        "id": { "type": "string" },
        "brandId": { "type": "string" },
        "title": { "type": "string" },
        "content": { "type": "string", "description": "The main content of the article in HTML format." },
        "description": { "type": "string" },
        "status": { "type": "string" },
        "statusInternal": { "type": "string" },
        "assigneeIds": { "type": "array", "items": { "type": "string" } },
        "startDate": { "type": "string", "format": "date-time" },
        "dueDate": { "type": "string", "format": "date-time" },
        "timeEstimate": { "type": "number" },
        "priority": { "type": "string" },
        "companyId": { "type": "string" },
        "lastActivity": { "$ref": "#/backend/entities/Activity" },
        "revisionItems": { "type": "array", "items": { "$ref": "#/backend/entities/RevisionItem" } },
        "revisionHistory": { "type": "array", "items": { "$ref": "#/backend/entities/RevisionCycle" } },
        "attachments": {
            "type": "array",
            "description": "A list of supporting files or links for this article.",
            "items": { "$ref": "#/backend/entities/Attachment" }
        },
        "deliverables": {
            "type": "array",
            "description": "A list of submitted files or links for this article, with historical versions.",
            "items": { "$ref": "#/backend/entities/Attachment" }
        },
        "actualStartDate": { "type": "string", "format": "date-time" },
        "actualCompletionDate": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "brandId", "title", "statusInternal", "assigneeIds", "priority", "companyId"]
    },
    "RevisionItem": {
        "$schema": "http://json-schema.org/draft-07/schema#",
        "title": "RevisionItem",
        "type": "object",
        "description": "A single checklist item for a revision request.",
        "properties": {
            "id": { "type": "string" },
            "text": { "type": "string" },
            "completed": { "type": "boolean" }
        },
        "required": ["id", "text", "completed"]
    },
    "RevisionCycle": {
        "$schema": "http://json-schema.org/draft-07/schema#",
        "title": "RevisionCycle",
        "type": "object",
        "description": "Represents one full cycle of revision feedback.",
        "properties": {
            "cycleNumber": { "type": "number" },
            "requestedAt": { "type": "string", "format": "date-time" },
            "requestedBy": {
                "type": "object",
                "properties": {
                    "id": { "type": "string" },
                    "name": { "type": "string" },
                    "avatarUrl": { "type": "string" }
                },
                "required": ["id", "name"]
            },
            "items": { "type": "array", "items": { "$ref": "#/backend/entities/RevisionItem" } }
        },
        "required": ["cycleNumber", "requestedAt", "requestedBy", "items"]
    },
    "Attachment": {
        "$schema": "http://json-schema.org/draft-07/schema#",
        "title": "Attachment",
        "type": "object",
        "description": "Represents a file attached to a task or submitted as a deliverable.",
        "properties": {
            "id": { "type": "string" },
            "name": { "type": "string" },
            "type": { "type": "string", "enum": ["local", "gdrive"] },
            "url": { "type": "string", "format": "uri" },
            "submittedAt": { "type": "string", "format": "date-time" },
            "submittedBy": { "$ref": "#/backend/entities/User" },
            "forRevisionCycle": { "type": "number" }
        },
        "required": ["id", "name", "type", "url"]
    },
    "TimeTracking": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "TimeTracking",
      "type": "object",
      "description": "Represents the time tracked for a specific task by a user.",
      "properties": {
        "id": { "type": "string" },
        "taskId": { "type": "string" },
        "userId": { "type": "string" },
        "startTime": { "type": "string", "format": "date-time" },
        "endTime": { "type": "string", "format": "date-time" },
        "duration": { "type": "number" }
      },
      "required": ["id", "taskId", "userId", "startTime", "endTime", "duration"]
    },
    "RecurringTaskTemplate": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "RecurringTaskTemplate",
      "type": "object",
      "description": "A template for creating tasks on a recurring schedule.",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "frequency": { "type": "string", "enum": ["daily", "weekly", "monthly"] },
        "daysOfWeek": {
          "type": "array",
          "items": { "type": "string", "enum": ["Sunday", "Monday", "Tuesday", "Wednesday", "Thursday", "Friday", "Saturday"] }
        },
        "dayOfMonth": { "type": "number" },
        "isMandatory": { "type": "boolean" },
        "defaultAssigneeIds": { "type": "array", "items": { "type": "string" } },
        "defaultPriority": { "type": "string", "enum": ["Urgent", "High", "Medium", "Low"] },
        "defaultBrandId": { "type": "string" },
        "companyId": { "type": "string" },
        "lastGeneratedAt": { "type": "string", "format": "date-time" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "title", "frequency", "defaultAssigneeIds", "companyId", "createdAt"]
    },
    "NavigationItem": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "NavigationItem",
      "type": "object",
      "properties": {
        "id": { "type": "string" }, "label": { "type": "string" }, "path": { "type": "string" },
        "icon": { "type": "string" }, "order": { "type": "number" },
        "roles": { "type": "array", "items": { "type": "string" } }
      },
      "required": ["id", "label", "path", "icon", "order", "roles"]
    },
    "Notification": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Notification",
      "type": "object",
      "properties": {
        "id": { "type": "string" }, "userId": { "type": "string" }, "title": { "type": "string" },
        "message": { "type": "string" }, "taskId": { "type": "string" }, "isRead": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" },
        "createdBy": {
          "type": "object", "properties": { "id": { "type": "string" }, "name": { "type": "string" }, "avatarUrl": { "type": "string" } },
          "required": ["id", "name"]
        }
      },
      "required": ["id", "userId", "title", "message", "taskId", "isRead", "createdAt", "createdBy"]
    },
    "WorkflowStatus": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "WorkflowStatus", "type": "object",
      "properties": {
        "id": { "type": "string" }, "name": { "type": "string" }, "order": { "type": "number" },
        "color": { "type": "string" }, "companyId": { "type": "string" }
      },
      "required": ["id", "name", "order", "color", "companyId"]
    },
     "Activity": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Activity", "type": "object",
      "properties": {
        "id": { "type": "string" },
        "user": {
          "type": "object", "properties": { "id": { "type": "string" }, "name": { "type": "string" }, "avatarUrl": { "type": "string" } },
          "required": ["id", "name"]
        },
        "action": { "type": "string" }, "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "user", "action", "timestamp"]
    },
    "SocialMediaPost": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "SocialMediaPost",
      "type": "object",
      "description": "Represents a social media post, which is a specialized type of task.",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string", "description": "Internal title for the post." },
        "brandId": { "type": "string" },
        "platform": { "type": "string", "enum": ["Instagram", "Facebook", "Twitter", "LinkedIn"] },
        "postType": { "type": "string", "enum": ["Upload", "Branding"], "description": "Category of the social media work."},
        "caption": { "type": "string", "description": "The text content of the post." },
        "mediaUrl": { "type": "string", "format": "uri", "description": "URL of the image or video for the post." },
        "status": { "type": "string", "enum": ["Draft", "Needs Approval", "Scheduled", "Posted", "Error"], "description": "Workflow status of the post." },
        "statusInternal": { "type": "string" },
        "assigneeIds": { "type": "array", "items": { "type": "string" } },
        "priority": { "type": "string", "enum": ["Urgent", "High", "Medium", "Low"] },
        "startDate": { "type": "string", "format": "date-time" },
        "dueDate": { "type": "string", "format": "date-time" },
        "timeEstimate": { "type": "number" },
        "scheduledAt": { "type": "string", "format": "date-time", "description": "The date and time the post is scheduled to be published." },
        "postedAt": { "type": "string", "format": "date-time", "description": "The actual timestamp when the post was published." },
        "createdBy": { "type": "string" },
        "companyId": { "type": "string" },
        "revisionItems": { "type": "array", "items": { "$ref": "#/backend/entities/RevisionItem" } },
        "revisionHistory": { "type": "array", "items": { "$ref": "#/backend/entities/RevisionCycle" } }
      },
      "required": ["id", "title", "platform", "caption", "status", "statusInternal", "scheduledAt", "createdBy", "companyId", "brandId", "assigneeIds", "priority"]
    },
    "SharedLink": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "SharedLink", "type": "object",
      "properties": {
        "id": { "type": "string" }, "name": { "type": "string" }, "companyId": { "type": "string" },
        "creatorRole": { "type": "string" }, "allowedNavItems": { "type": "array", "items": { "type": "string" } },
        "navItems": { "type": "array", "items": { "$ref": "#/backend/entities/NavigationItem" } },
        "brandIds": { "type": "array", "items": { "type": "string" } }, "password": { "type": "string" },
        "expiresAt": { "type": "string", "format": "date-time" },
        "accessLevel": { "type": "string", "enum": ["view", "status", "limited-edit"] },
        "snapshot": {
            "type": "object",
            "properties": {
                "tasks": { "type": "array", "items": { "$ref": "#/backend/entities/Task" } },
                "socialMediaPosts": { "type": "array", "items": { "$ref": "#/backend/entities/SocialMediaPost" } },
                "webArticles": { "type": "array", "items": { "$ref": "#/backend/entities/WebArticle" } },
                "statuses": { "type": "array", "items": { "$ref": "#/backend/entities/WorkflowStatus" } },
                "users": { "type": "array", "items": { "$ref": "#/backend/entities/User" } },
                "brands": { "type": "array", "items": { "$ref": "#/backend/entities/Brand" } }
            },
            "required": ["tasks", "statuses", "users", "brands"]
        },
        "createdBy": { "type": "string" }, "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "name", "companyId", "creatorRole", "allowedNavItems", "navItems", "accessLevel", "snapshot", "createdBy", "createdAt"]
    },
    "SocialMediaConnection": {
        "$schema": "http://json-schema.org/draft-07/schema#",
        "title": "SocialMediaConnection",
        "type": "object",
        "description": "Stores credentials for a social media platform connection.",
        "properties": {
            "id": { "type": "string" },
            "platform": { "type": "string", "enum": ["instagram"] },
            "userId": { "type": "string", "description": "The Firebase UID of the user who initiated the connection." },
            "companyId": { "type": "string" },
            "instagramUserId": { "type": "string", "description": "The User ID from the Instagram Graph API." },
            "instagramUsername": { "type": "string" },
            "accessToken": { "type": "string", "description": "The long-lived access token." },
            "expiresAt": { "type": "string", "format": "date-time" },
            "connectedAt": { "type": "string", "format": "date-time" }
        },
        "required": ["id", "platform", "userId", "companyId", "instagramUserId", "accessToken", "expiresAt"]
    }
  },
  "auth": {
    "providers": [
      "password"
    ]
  },
  "firestore": {
    "structure": [
      { "path": "/users/{userId}", "definition": { "entityName": "User", "schema": { "$ref": "#/backend/entities/User" } } },
      { "path": "/companies/{companyId}", "definition": { "entityName": "Company", "schema": { "$ref": "#/backend/entities/Company" } } },
      { "path": "/companySettings/{companyId}", "definition": { "entityName": "CompanySettings", "schema": { "$ref": "#/backend/entities/CompanySettings" } } },
      { "path": "/brands/{brandId}", "definition": { "entityName": "Brand", "schema": { "$ref": "#/backend/entities/Brand" } } },
      { "path": "/tasks/{taskId}", "definition": { "entityName": "Task", "schema": { "$ref": "#/backend/entities/Task" } } },
      { "path": "/tasks/{taskId}/timeTracking/{timeTrackingId}", "definition": { "entityName": "TimeTracking", "schema": { "$ref": "#/backend/entities/TimeTracking" } } },
      { "path": "/tasks/{taskId}/activities/{activityId}", "definition": { "entityName": "Activity", "schema": { "$ref": "#/backend/entities/Activity" } } },
      { "path": "/navigationItems/{navItemId}", "definition": { "entityName": "NavigationItem", "schema": { "$ref": "#/backend/entities/NavigationItem" } } },
      { "path": "/users/{userId}/notifications/{notificationId}", "definition": { "entityName": "Notification", "schema": { "$ref": "#/backend/entities/Notification" } } },
      { "path": "/statuses/{statusId}", "definition": { "entityName": "WorkflowStatus", "schema": { "$ref": "#/backend/entities/WorkflowStatus" } } },
      { "path": "/socialMediaPosts/{postId}", "definition": { "entityName": "SocialMediaPost", "schema": { "$ref": "#/backend/entities/SocialMediaPost" } } },
      { "path": "/webArticles/{articleId}", "definition": { "entityName": "WebArticle", "schema": { "$ref": "#/backend/entities/WebArticle" } } },
      { "path": "/sharedLinks/{linkId}", "definition": { "entityName": "SharedLink", "schema": { "$ref": "#/backend/entities/SharedLink" } } },
      { "path": "/socialMediaConnections/{connectionId}", "definition": { "entityName": "SocialMediaConnection", "schema": { "$ref": "#/backend/entities/SocialMediaConnection" } } },
      { "path": "/api/instagram/publish", "definition": { "description": "An API endpoint to publish a post to Instagram." } },
      { "path": "/api/run-scheduler", "definition": { "description": "An API endpoint that runs scheduled jobs like posting social media content." } }
    ]
  }
}
