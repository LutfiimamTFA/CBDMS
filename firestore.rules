rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- Helper Functions ---
    function isSignedIn() { return request.auth != null; }

    function getUserData(userId) {
      return get(/databases/$(database)/documents/users/$(userId)).data;
    }

    function getRequestingUserData() {
      return getUserData(request.auth.uid);
    }

    function getCompanySettings(companyId) {
      return get(/databases/$(database)/documents/companySettings/$(companyId)).data;
    }

    function isEmergencyAdmin(userId) {
      let userCompanyId = getUserData(userId).companyId;
      return exists(/databases/$(database)/documents/companySettings/$(userCompanyId)) &&
             getCompanySettings(userCompanyId).emergencyAdminUserId == userId;
    }

    function isSuperAdmin() {
      return isSignedIn() && (request.auth.token.role == 'Super Admin' || isEmergencyAdmin(request.auth.uid));
    }

    function getPermissions() {
      return get(/databases/$(database)/documents/permissions/roles).data;
    }

    function hasPermission(role, permission) {
      return getPermissions()[role][permission] == true;
    }

    function isRole(role) {
      return isSignedIn() && request.auth.token.role == role;
    }

    function isSameCompanyAsRequestingUser(entityCompanyId) {
      return getRequestingUserData().companyId == entityCompanyId;
    }

    function isAssignee(taskId) {
      return request.auth.uid in get(/databases/$(database)/documents/tasks/$(taskId)).data.assigneeIds;
    }

    function isCreator(userId, task) {
      return task.createdBy.id == userId;
    }

    function isManagerOf(userId) {
      return isSignedIn() && getUserData(userId).managerId == request.auth.uid;
    }

    function isOwnRecord(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function managerManagesBrand(brandId) {
      return isSignedIn() && isRole('Manager') && brandId in getRequestingUserData().brandIds;
    }

    // --- SHARE VIEW RULES (PUBLIC READ) ---
    match /sharedLinks/{linkId} {
      allow get: if true;
      allow list: if false;
      allow write: if isSignedIn() && (isSuperAdmin() || isRole('Manager'));
    }

    // --- LOGGED-IN USER RULES ---

    match /companies/{companyId} {
      allow get: if isSignedIn();
      allow write: if isSuperAdmin() && isSameCompanyAsRequestingUser(companyId);
    }

    match /brands/{brandId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn();
      allow write: if isSuperAdmin() || isRole('Manager');
    }

    match /statuses/{statusId} {
      allow read: if isSignedIn();
      allow write: if isSuperAdmin();
    }
    
    match /socialMediaStatuses/{statusId} {
      allow read: if isSignedIn();
      allow write: if isSuperAdmin();
    }
    
    match /webStatuses/{statusId} {
      allow read: if isSignedIn();
      allow write: if isSuperAdmin();
    }

    match /navigationItems/{navItemId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn();
      allow write: if isSuperAdmin();
    }

    match /users/{userId} {
      allow get: if isSignedIn();
      allow update: if isSuperAdmin() ||
        (isRole('Manager') && hasPermission('Manager', 'canManageUsers') && isManagerOf(userId)) ||
        isOwnRecord(userId);

      allow create: if (isSuperAdmin() && request.resource.data.role == 'Manager') ||
        (isRole('Manager') && hasPermission('Manager', 'canManageUsers') &&
          (request.resource.data.role in ['Employee', 'PIC', 'Client']));

      allow delete: if isSuperAdmin() ||
        (isRole('Manager') && hasPermission('Manager', 'canDeleteUsers') && isManagerOf(userId));

      match /notifications/{notificationId} {
        allow read, update, delete: if isOwnRecord(userId);
        allow create: if isSignedIn();
      }
    }

    match /tasks/{taskId} {
      allow get, list: if isSignedIn();

      allow create: if isSuperAdmin() ||
        (isRole('Manager') && hasPermission('Manager', 'canCreateTasks')) ||
        (isRole('Employee') && hasPermission('Employee', 'canCreateTasks'));

      allow update: if isSuperAdmin() ||
        (isRole('Manager') && managerManagesBrand(resource.data.brandId)) ||
        ((isRole('Employee') || isRole('PIC')) && isAssignee(taskId) &&
          isCreator(request.auth.uid, resource.data) && resource.data.status != 'Done');

      allow delete: if isSuperAdmin() ||
        (isRole('Manager') && hasPermission('Manager', 'canDeleteTasks') && managerManagesBrand(resource.data.brandId));

      match /timeTracking/{timeTrackingId} {
        allow read, create, update, delete: if isSuperAdmin() ||
          (isRole('Manager') && managerManagesBrand(get(/databases/$(database)/documents/tasks/$(taskId)).data.brandId)) ||
          ((isRole('Employee') || isRole('PIC')) && isAssignee(taskId) && hasPermission('Employee', 'canTrackTime'));
      }

      match /activities/{activityId} {
        allow read, create: if isSuperAdmin() ||
          (isRole('Manager') && managerManagesBrand(get(/databases/$(database)/documents/tasks/$(taskId)).data.brandId)) ||
          ((isRole('Employee') || isRole('PIC')) && isAssignee(taskId));
        allow update, delete: if false;
      }
    }

    match /socialMediaPosts/{postId} {
      allow get, list: if isSignedIn();
      allow create: if isSuperAdmin() || isRole('Manager') || isRole('Employee');
      allow update: if isSuperAdmin() ||
        (isRole('Manager') && managerManagesBrand(resource.data.brandId)) ||
        (isOwnRecord(resource.data.createdBy) && resource.data.statusInternal != 'Done');
      allow delete: if isSuperAdmin() || (isRole('Manager') && managerManagesBrand(resource.data.brandId));
    }

    match /webArticles/{articleId} {
      allow get, list: if isSignedIn();
      allow create: if isSuperAdmin() || isRole('Manager') || isRole('Employee');
      allow update: if isSuperAdmin() ||
        (isRole('Manager') && managerManagesBrand(resource.data.brandId)) ||
        (isOwnRecord(resource.data.createdBy) && resource.data.statusInternal != 'Done');
      allow delete: if isSuperAdmin() || (isRole('Manager') && managerManagesBrand(resource.data.brandId));
    }

    match /socialMediaConnections/{connectionId} {
      allow read: if isSignedIn() && isSameCompanyAsRequestingUser(resource.data.companyId);
      allow write: if isSuperAdmin() ||
        (isRole('Manager') && isSameCompanyAsRequestingUser(request.resource.data.companyId));
    }

    match /permissions/{docId} {
      allow read, write: if isSuperAdmin();
    }

    match /companySettings/{companyId} {
      allow read: if isSignedIn() && isSameCompanyAsRequestingUser(companyId);
      allow write: if isSuperAdmin();
    }

    match /recurringTaskTemplates/{templateId} {
      allow read, write: if isSuperAdmin() ||
        (isRole('Manager') && managerManagesBrand(resource.data.defaultBrandId));
    }

    match /dailyReports/{reportId} {
      allow read: if isSuperAdmin() || (isRole('Manager') && isManagerOf(resource.data.userId));
      allow write: if (isRole('Employee') || isRole('PIC')) && isOwnRecord(resource.data.userId);
    }
  }
}
